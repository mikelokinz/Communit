datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum CallRole {
  HOST
  GUEST
  MODERATOR
}

enum RoomType {
  DIRECT
  GROUP
}

model User {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String            @unique @db.VarChar(50)
  email        String            @unique @db.VarChar(255)
  passwordHash String            @db.VarChar(255)
  name         String?           @db.VarChar(100)
  createdAt    DateTime          @default(now()) @db.Timestamp(6)
  updatedAt    DateTime          @updatedAt @db.Timestamp(6)

  // Relations
  sessions       UserSession[]
  participants   RoomParticipant[]
  messages       Message[]
  contacts       ContactLink[]     @relation("UserContacts")
  contactOf      ContactLink[]     @relation("LinkedUsers")
  hostedMeetings Meeting[]         @relation("HostedMeetings")
  meetingInvites MeetingInvite[]

  @@index([email])
}

model UserSession {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  token     String   @unique @db.VarChar(512)
  expiresAt DateTime @db.Timestamp(6)
  createdAt DateTime @default(now()) @db.Timestamp(6)

  // Relations
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Room {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type         RoomType          @default(GROUP)
  name         String            @db.VarChar(100) @default("Untitled Room")
  slug         String            @unique @db.VarChar(100)
  createdAt    DateTime          @default(now()) @db.Timestamp(6)
  updatedAt    DateTime          @updatedAt @db.Timestamp(6)

  // Relations
  participants RoomParticipant[]
  messages     Message[]

  @@index([slug])
}

model RoomParticipant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId    String   @db.Uuid
  userId    String   @db.Uuid
  role      CallRole @default(GUEST)
  joinedAt  DateTime @default(now()) @db.Timestamp(6)
  isPinned  Boolean  @default(false)
  isBlocked Boolean  @default(false)

  // Relations
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
}

enum MessageType {
  TEXT
  FILE
  VOICE
  IMAGE
  WHITEBOARD
  SYSTEM
}

model Message {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roomId        String      @db.Uuid
  userId        String      @db.Uuid
  body          String      @db.Text
  type          MessageType @default(TEXT)
  isEdited      Boolean     @default(false)
  parentId      String?     @db.Uuid
  fileUrl       String?     @db.Text
  fileName      String?     @db.VarChar(500)
  fileMimeType  String?     @db.VarChar(100)
  fileSizeBytes Int?
  createdAt     DateTime    @default(now()) @db.Timestamp(6)
  updatedAt     DateTime?   @updatedAt

  // Relations
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent    Message? @relation("MessageReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("MessageReplies")

  @@index([roomId])
  @@index([createdAt])
}

model ContactLink {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @db.Uuid
  contactId  String   @db.Uuid
  customName String?  @db.VarChar(100)
  createdAt  DateTime @default(now()) @db.Timestamp(6)

  // Relations
  user      User     @relation("UserContacts", fields: [userId], references: [id], onDelete: Cascade)
  contact   User     @relation("LinkedUsers", fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([userId, contactId])
}

model Meeting {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hostId    String          @db.Uuid
  title     String          @db.VarChar(200) @default("Untitled Meeting")
  code      String          @unique @db.VarChar(20)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now()) @db.Timestamp(6)

  // Relations
  host      User            @relation("HostedMeetings", fields: [hostId], references: [id], onDelete: Cascade)
  invites   MeetingInvite[]
}

model MeetingInvite {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  meetingId String   @db.Uuid
  userId    String   @db.Uuid
  seen      Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamp(6)

  // Relations
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
}
